# Database — leave as sqlite for local dev; set to postgresql:// in production
DATABASE_URL=sqlite:///./enquiries.db

# Admin dashboard token — change to a long random secret in production
# Generate one with: openssl rand -hex 32
ADMIN_SECRET_TOKEN=change-this-to-a-random-secret

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Email notifications via Resend (https://resend.com — 100 emails/day free)
# Leave blank to disable email notifications
RESEND_API_KEY=
EMAIL_RECIPIENT=yatendra@ypassociates.in
