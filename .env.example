# ── Backend (backend/.env) ────────────────────────────────────────────────────

# Database connection string
# SQLite for local dev, PostgreSQL for production
DATABASE_URL=sqlite:///./enquiries.db
# DATABASE_URL=postgresql://user:password@host:5432/ypassociates

# Admin dashboard token — generate with: openssl rand -hex 32
ADMIN_SECRET_TOKEN=change-this-to-a-random-secret

# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Email via Resend (https://resend.com — 100 emails/day free)
# Leave blank to disable email notifications
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_RECIPIENT=yatendra@ypassociates.in

# ── Frontend (frontend/.env) ──────────────────────────────────────────────────

# Backend API base URL (no trailing slash)
VITE_API_URL=http://localhost:8000
# Production: VITE_API_URL=https://api.ypassociates.in
